# =============================================================================
# ChiaExplorer — configuration template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to the repository — it contains passwords!
#            Make sure .env is in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL (required)
# -----------------------------------------------------------------------------

# Full connection string (DSN) — used by all scripts
PG_DSN=postgresql://USER:PASSWORD@HOST:5432/chia

# Individual components (optional, for reference / other tools)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chia
DB_USER=your_user
DB_PASSWORD=your_password


# -----------------------------------------------------------------------------
# SQLite — Chia node database (optional)
# -----------------------------------------------------------------------------

# If not set, the default path is used:
#   Windows: C:\Users\<USERNAME>\downloads\mainnet\blockchain_v2_mainnet.sqlite
#   Linux/macOS: ~/downloads/mainnet/blockchain_v2_mainnet.sqlite

# SQLITE_PATH=C:\Users\YourName\downloads\mainnet\blockchain_v2_mainnet.sqlite


# -----------------------------------------------------------------------------
# Import parameters (optional, defaults are fine)
# -----------------------------------------------------------------------------

# Block height step per main loop iteration
# IMPORT_STEP=200000

# INSERT batch size for blocks table
# BATCH_SIZE_BLOCKS=20000

# INSERT batch size for coins table (reduce to 50000 if low on RAM)
# BATCH_SIZE_COINS=100000
