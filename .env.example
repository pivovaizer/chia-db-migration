# =============================================================================
# ChiaExplorer — пример файла конфигурации
# =============================================================================
# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env
#
# ВАЖНО: Никогда не коммить .env в репозиторий — он содержит пароли!
#         Убедись, что .env добавлен в .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL (обязательно)
# -----------------------------------------------------------------------------

# Полная строка подключения (DSN) — используется во всех скриптах
PG_DSN=postgresql://USER:PASSWORD@HOST:5432/chia

# Отдельные компоненты (опционально, для справки / других инструментов)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chia
DB_USER=your_user
DB_PASSWORD=your_password


# -----------------------------------------------------------------------------
# SQLite — база данных Chia-ноды (опционально)
# -----------------------------------------------------------------------------

# Если не задано, используется путь по умолчанию:
#   Windows: C:\Users\<USERNAME>\downloads\mainnet\blockchain_v2_mainnet.sqlite
#   Linux/macOS: ~/downloads/mainnet/blockchain_v2_mainnet.sqlite

# SQLITE_PATH=C:\Users\YourName\downloads\mainnet\blockchain_v2_mainnet.sqlite


# -----------------------------------------------------------------------------
# Параметры импорта (опционально, можно не трогать)
# -----------------------------------------------------------------------------

# Шаг по высоте блока за одну итерацию основного цикла
# IMPORT_STEP=200000

# Размер INSERT-батча для таблицы blocks
# BATCH_SIZE_BLOCKS=20000

# Размер INSERT-батча для таблицы coins (уменьши до 50000 если не хватает RAM)
# BATCH_SIZE_COINS=100000
